def _print_banner(version, inner_width=60):
    text = f"  GOcontroll Identify  V{version}"
    print(f"{_ORANGE}{text}{_RESET}")
    print("-" * (inner_width + 2))
    print()


# ─────────────────────────────────────────────────────────────
# Box-drawing renderer
# ─────────────────────────────────────────────────────────────

def _kv_box_width(title, rows):
    """Compute the natural inner width for a _kv_box."""
    if not rows:
        return 0
    kw = max(len(k) for k, _ in rows)
    vw = max(max(len(str(v)) for _, v in rows), 38)
    w = 2 + kw + 3 + vw + 1
    title_line = f"  {title}"
    if len(title_line) + 1 > w:
        w = len(title_line) + 1
    return w


def _table_box_width(title, headers, rows):
    """Compute the natural inner width for a _table_box."""
    if not rows:
        return 0
    widths = [len(h) for h in headers]
    for row in rows:
        for i, cell in enumerate(row):
            if i < len(widths):
                widths[i] = max(widths[i], len(str(cell)))
    inner_w = sum(w + 2 for w in widths) + len(widths) - 1
    title_content = f"  {title}"
    if len(title_content) + 1 > inner_w:
        inner_w = len(title_content) + 1
    return inner_w


def _kv_box(title, rows, min_width=0):
    """
    Render a single-column key/value box:
    ╔═══════════════════════════╗
    ║  TITLE                    ║
    ╠═══════════════════════════╣
    ║  key     │ value          ║
    ╚═══════════════════════════╝
    """
    if not rows:
        return
    kw = max(len(k) for k, _ in rows)
    # Compute total inner width: "  " + kw + " │ " + value + " "
    # Minimum value width = 38 so the box isn't too narrow
    vw = max(max(len(str(v)) for _, v in rows), 38)
    w = 2 + kw + 3 + vw + 1          # total inner width
    title_line = f"  {title}"
    if len(title_line) + 1 > w:
        w = len(title_line) + 1
    if min_width > w:
        vw += min_width - w
        w = min_width

    print(f"╔{'═'*w}╗")
    print(f"║{title_line:<{w}}║")
    print(f"╠{'═'*w}╣")
    for k, v in rows:
        val = str(v)
        # Truncate long values with ellipsis
        if len(val) > vw:
            val = val[:vw-1] + "…"
        print(f"║  {k:<{kw}} │ {val:<{vw}} ║")
    print(f"╚{'═'*w}╝")
    print()


def _table_box(title, headers, rows, min_width=0, col_widths=None):
    """
    Render a multi-column table box:
    ╔═══════════════════════════════════════╗
    ║  TITLE                                ║
    ╠══════╦══════════════╦════════╦════════╣
    ║ Col1 ║ Col2         ║ Col3   ║ Col4   ║
    ╠══════╬══════════════╬════════╬════════╣
    ║  1   ║ value        ║ ...    ║ ...    ║
    ╚══════╩══════════════╩════════╩════════╝
    """
    if col_widths is not None:
        widths = list(col_widths)
    else:
        widths = [len(h) for h in headers]
        for row in rows:
            for i, cell in enumerate(row):
                if i < len(widths):
                    widths[i] = max(widths[i], len(str(cell)))

    def hline(l="╠", m="╬", r="╣", f="═"):
        return l + m.join(f * (w + 2) for w in widths) + r

    def data_row(cells):
        parts = []
        for i, w in enumerate(widths):
            cell = str(cells[i]) if i < len(cells) else ""
            if len(cell) > w:
                cell = cell[:w - 1] + "…"
            parts.append(f" {cell:<{w}} ")
        return "║" + "║".join(parts) + "║"

    inner_w = sum(w + 2 for w in widths) + len(widths) - 1
    # Ensure title section is at least as wide
    title_content = f"  {title}"
    if len(title_content) + 1 > inner_w:
        widths[-1] += len(title_content) + 1 - inner_w
        inner_w = len(title_content) + 1
    if min_width > inner_w:
        widths[-1] += min_width - inner_w
        inner_w = min_width

    print(f"╔{'═'*inner_w}╗")
    print(f"║{title_content:<{inner_w}}║")
    print(hline("╠", "╦", "╣"))
    print(data_row(headers))
    print(hline("╠", "╬", "╣"))
    for row in rows:
        print(data_row(row))
    print(hline("╚", "╩", "╝"))
    print()


