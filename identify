    # ── INSTALLED MODULES ───────────────────────────────────
    if mod_rows:
        _table_box(
            "INSTALLED MODULES",
            ["Slot", "Type", "HW Version", "SW Version"],
            mod_rows,
            min_width=max_w,
        )
    else:
